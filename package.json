{
  "name": "3d-models",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --bun run next dev",
    "dev:inspect": "bun --bun run next dev --inspect",
    "next:upgrade": "next upgrade",
    "next:analyze": "next experimental-analyze",
    "build": "bun --bun run next build",
    "build:debug": "bun --bun run next build --debug-prerender",
    "start": "bun --bun run next start",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:unit": "bun test tests/unit",
    "test:components": "bun test tests/components",
    "test:integration": "bun test tests/integration",
    "test:e2e": "playwright test",
    "e2e:open": "playwright test --ui",
    "e2e:codegen": "playwright codegen http://localhost:3000",
    "typegen": "next typegen && tsgo --noEmit",
    "env:typegen": "varlock typegen",
    "db:generate": "varlock run -- drizzle-kit generate",
    "db:migrate": "varlock run -- drizzle-kit migrate",
    "db:push": "varlock run -- drizzle-kit push",
    "db:studio": "varlock run -- drizzle-kit studio",
    "db:seed": "varlock run -- bun --conditions=react-server src/db/seed.ts",
    "db:drop": "varlock run -- bun --conditions=react-server src/db/drop-tables.ts",
    "prepare": "husky",
    "type": "tsgo --noEmit --skipLibCheck --project tsconfig.json",
    "fix": "ultracite fix",
    "check": "ultracite check",
    "doctor": "ultracite doctor",
    "ultracite:upgrade": "bun x ultracite@latest init --pm bun --linter biome --agents cursor-cli --editors vscode --hooks cursor --frameworks next --quiet"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.5.6",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@neondatabase/serverless": "^1.0.2",
    "@varlock/bitwarden-plugin": "^0.0.6",
    "@varlock/nextjs-integration": "^0.3.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "better-auth": "^1.5.6",
    "clsx": "^2.1.1",
    "drizzle-orm": "beta",
    "elysia": "^1.4.28",
    "next": "^16.2.2",
    "nuqs": "^2.8.9",
    "react": "canary",
    "react-dom": "canary",
    "react-icons": "^5.6.0",
    "server-only": "^0.0.1",
    "slugify": "^1.6.9",
    "valibot": "^1.3.1",
    "varlock": "^0.7.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@happy-dom/global-registrator": "^20.8.9",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@toolwind/corner-shape": "^0.0.8-3",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260403.1",
    "drizzle-kit": "beta",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "next-devtools-mcp": "^0.3.10",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "typescript-plugin-directives": "^0.0.3",
    "ultracite": "7.4.3"
  },
  "trustedDependencies": [
    "@prisma/client",
    "@prisma/engines",
    "@swc/core",
    "@tailwindcss/oxide",
    "esbuild",
    "prisma",
    "sharp"
  ],
  "overrides": {
    "@next/env": "npm:@varlock/nextjs-integration",
    "tmp": ">=0.2.4",
    "glob": "^12.0.0",
    "body-parser": "^2.2.1",
    "express": "^5.2.0",
    "@modelcontextprotocol/sdk": ">1.25.3",
    "jws": "^3.2.3",
    "@trpc/server": ">=11.8.0",
    "qs": ">6.14.1",
    "@sinclair/typebox": "0.34.46",
    "undici": ">=7.24.0",
    "hono": ">=4.12.7",
    "@hono/node-server": ">=1.19.10",
    "lodash": ">4.17.22",
    "@isaacs/brace-expansion": ">5.0.0",
    "ajv": ">=8.18.0",
    "minimatch": ">=10.2.3",
    "lightningcss": "^1.31.0",
    "zod": ">=4.0.0",
    "express-rate-limit": ">=8.2.2",
    "kysely": ">0.28.11",
    "brace-expansion": ">=5.0.5",
    "yaml": ">=2.8.3",
    "picomatch": ">=4.0.4",
    "path-to-regexp": ">=8.4.0"
  }
}
