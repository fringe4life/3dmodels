{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "src/app/index.{ts,tsx,js,jsx}",
    "src/app/main.{ts,tsx,js,jsx}",
    "panda.config.ts",
    "next.config.ts"
  ],
  "rules": {
    "unused-dependencies": "warn"
  },
  "ignorePatterns": [
    "*.spec.ts",
    "*.spec.tsx",
    "*.test.ts",
    "*.test.tsx",
    "doctor.config.ts"
  ],
  "ignoreDependencies": [
    "@varlock/bitwarden-plugin",
    "babel-plugin-react-compiler",
    "next-devtools-mcp",
    "@pandacss/preset-panda",
    "react-doctor",
    "@styled-system/css",
    "@styled-system/patterns",
    "@styled-system/recipes"
  ],
  "duplicates": {
    "enabled": true,
    "minOccurrences": 3
  }
}
